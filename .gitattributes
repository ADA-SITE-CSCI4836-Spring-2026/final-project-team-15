# Auto-detect text files and normalize line endings on commit
* text=auto

# Unity YAML text assets — must be LF for Unity's YAML merge tool
*.cs        text diff=csharp
*.shader    text
*.cginc     text
*.hlsl      text
*.compute   text
*.uss       text
*.uxml      text
*.json      text
*.xml       text
*.txt       text
*.md        text
*.yml       text
*.yaml      text
*.meta      text merge=unityyamlmerge eol=lf
*.unity     text merge=unityyamlmerge eol=lf
*.asset     text merge=unityyamlmerge eol=lf
*.prefab    text merge=unityyamlmerge eol=lf
*.mat       text merge=unityyamlmerge eol=lf
*.anim      text merge=unityyamlmerge eol=lf
*.controller text merge=unityyamlmerge eol=lf
*.physicMaterial text merge=unityyamlmerge eol=lf
*.physicsMaterial2D text merge=unityyamlmerge eol=lf

# Binary assets — never diff or merge
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.tga       binary
*.tiff      binary
*.bmp       binary
*.exr       binary
*.hdr       binary
*.fbx       binary
*.obj       binary
*.blend     binary
*.dae       binary
*.3ds       binary
*.mp3       binary
*.ogg       binary
*.wav       binary
*.mp4       binary
*.mov       binary
*.unitypackage binary
*.dll       binary
*.so        binary
*.dylib     binary
*.ttf       binary
*.otf       binary
